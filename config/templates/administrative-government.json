  "workflow": {
    "enabled": true,
    "defaultFlow": ["orchestrator", "dispatcher", "executor", "tester"],
    "autoSupervise": true,
    "allowFallback": true,
    "reception": {
      "enabled": true,
      "agentId": "reception_1",
      "welcomeMessage": "您好！欢迎来到行政服务中心，我是导办员。请问您要办理什么业务？我来帮您引导和解答。"
    }
  }
