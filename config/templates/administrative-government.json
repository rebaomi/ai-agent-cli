  "type": "administrative",
  "agents": [
    {
      "id": "director_1",
      "name": "中心主任",
      "role": "supervisor",
      "description": "中心主任，负责整体工作协调和重大事项决策",
      "status": "idle",
      "capabilities": ["行政决策", "政策解读", "统筹协调"]
    },
    {
      "id": "reception_1",
      "name": "导办员",
      "role": "orchestrator",
      "description": "前台接待和引导，负责初步接待和需求分类",
      "status": "idle",
      "capabilities": ["咨询服务", "材料预审", "业务分流"]
    },
    {
      "id": "section_chief_1",
      "name": "综合科科长",
