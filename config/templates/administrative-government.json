      "description": "负责各类证照的受理和办理",
      "status": "idle",
      "capabilities": ["证照办理", "材料审核", "流程办理"]
    },
    {
      "id": "clerk_tax",
      "name": "税务办理员",
      "role": "executor",
      "description": "负责税务相关业务办理",
      "status": "idle",
      "capabilities": ["税务登记", "申报指导", "政策解答"]
    },
    {
      "id": "clerk_civil",
      "name": "民政办事员",
      "role": "executor",
      "description": "负责民政类业务办理",
      "status": "idle",
      "capabilities": ["婚姻登记", "社保办理", "救助申请"]
    },
    {
      "id": "auditor_1",
      "name": "审核员",
      "role": "tester",
